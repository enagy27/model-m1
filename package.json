{
  "name": "model-m1",
  "version": "2.1.0",
  "description": "CLI tool and SDK for adjusting settings on the Marantz Model M1",
  "keywords": [
    "marantz",
    "heos",
    "model-m1"
  ],
  "homepage": "https://github.com/enagy27/model-m1#readme",
  "bugs": {
    "url": "https://github.com/enagy27/model-m1/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enagy27/model-m1.git"
  },
  "license": "GPL-3.0-only",
  "author": "enagy27",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "imports": {
    "#*": "./*"
  },
  "bin": {
    "model-m1": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:schema": "npx tsx scripts/generateSchema.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fast-xml-builder": "^1.1.4",
    "fast-xml-parser": "^5.5.6",
    "qs": "^6.15.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@types/qs": "^6.14.0",
    "@valibot/to-json-schema": "^1.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-morph": "^28.0.0",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{js,ts}": "eslint --fix"
  }
}
